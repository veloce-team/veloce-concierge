# Telegram
TG_BOT_TOKEN=123456:replace-with-token-from-botfather
# 32+ random characters; used as X-Telegram-Bot-Api-Secret-Token
TG_WEBHOOK_SECRET=replace-with-at-least-32-random-characters-xx

# Bitrix24 incoming webhook with CRM permissions
BITRIX24_WEBHOOK_URL=https://your-portal.bitrix24.ru/rest/1/your-key-here/
BITRIX24_DEAL_CATEGORY_ID=0

# Storage
SQLITE_PATH=/data/concierge.sqlite

# HTTP
# PUBLIC_URL = базовый URL, на котором Caddy проксирует /webhook/tg и /health.
#   Helsinki (Aeza, боевой TG-бот):  https://bot.veloce.team
#   Moscow (TimeWeb, fallback / dev): https://api.veloce.team
PUBLIC_URL=https://bot.veloce.team
PORT=3000

# TG-нотификация лидов (handler /internal/notify-lead)
# SECRET — общий с web/.env (32+ байт hex)
# OPERATOR_CHAT_ID — chat_id группы «Veloce — лиды» (отрицательное число)
LEAD_NOTIFICATION_SECRET=
OPERATOR_CHAT_ID=

# Runtime
NODE_ENV=production
LOG_LEVEL=info
