# Битрикс24 (общий с bot/, копируем значение)
BITRIX24_WEBHOOK_URL=https://your-portal.bitrix24.ru/rest/1/<webhook-key>/

# Кто ответственный за создаваемые Сделки. На портале veloce единственный пользователь — ID=1.
ASSIGNED_BY_ID=1

# CORS allow-list (JSON-массив строк).
# veloce.team — основной сайт. maxbot-pro.ru — продуктовый сайт
# max-microsite, фронт делает cross-origin POST на /api/lead/maxbot.
CORS_ORIGINS=["https://veloce.team","https://www.veloce.team","https://maxbot-pro.ru"]

# Rate-limit
RATE_LIMIT_WINDOW_MS=600000
RATE_LIMIT_MAX=5

# SQLite
DB_PATH=/data/web.sqlite

# Idempotency
IDEMPOTENCY_TTL_MS=600000

# HTTP-server
PORT=3000

# Логирование
LOG_LEVEL=info
NODE_ENV=production
