# Snippet: вставляется в блок api.veloce.team существующего Caddyfile.
# Поднимает reverse_proxy на контейнер concierge-bot только для /webhook/tg и /health.
# /metrics остаётся внутри docker-сети и наружу НЕ выставляется.

api.veloce.team {
    @bot path /webhook/tg /webhook/tg/* /health
    handle @bot {
        reverse_proxy concierge-bot:3000
    }
    handle {
        respond "Veloce API — coming soon" 200
    }
}
