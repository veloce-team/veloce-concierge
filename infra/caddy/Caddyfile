api.veloce.team {
	@bot path /webhook/tg /webhook/tg/* /health
	handle @bot {
		reverse_proxy concierge-bot:3000
	}
	handle {
		respond "Veloce API — coming soon" 200
	}
}

app.veloce.team {
	respond "Veloce Mini App — coming soon" 200
}

veloce.team, www.veloce.team {
	handle /branding/* {
		root * /srv
		file_server
		header Cache-Control "public, max-age=86400"
	}

	handle {
		root * /srv/veloce-site
		file_server
		encode gzip zstd

		header {
			Strict-Transport-Security "max-age=31536000; includeSubDomains"
			X-Content-Type-Options nosniff
			X-Frame-Options DENY
			Referrer-Policy strict-origin-when-cross-origin
		}
	}

	@www host www.veloce.team
	redir @www https://veloce.team{uri} permanent

	log {
		output file /var/log/caddy/veloce-site.log
		format json
	}
}
